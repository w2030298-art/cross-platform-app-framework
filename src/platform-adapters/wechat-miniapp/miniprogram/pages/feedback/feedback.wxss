.form-card {
  padding: var(--spacing-lg);
}

.form-group {
  margin-bottom: var(--spacing-lg);
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
  margin-bottom: var(--spacing-sm);
}

.form-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-placeholder);
  margin-top: 8rpx;
}

.submit-btn {
  margin-top: var(--spacing-lg);
  width: 100%;
}

.submit-btn[disabled] {
  opacity: 0.6;
}
