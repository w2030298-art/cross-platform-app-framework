<view class="page">
  <text class="page-title">我的收藏</text>

  <empty-state wx:if="{{empty}}" text="还没有收藏内容"></empty-state>

  <block wx:else>
    <view class="fav-list">
      <view
        wx:for="{{list}}"
        wx:key="id"
        class="fav-item card"
      >
        <view
          class="fav-content"
          data-id="{{item.id}}"
          bindtap="onItemTap"
        >
          <text class="fav-title">{{item.title}}</text>
          <text class="fav-summary">{{item.summary}}</text>
          <view class="fav-meta">
            <text class="tag">{{item.category}}</text>
            <text class="fav-date">{{item.publishedAt}}</text>
          </view>
        </view>
        <view
          class="fav-remove"
          data-id="{{item.id}}"
          bindtap="onRemoveTap"
        >
          <text>取消收藏</text>
        </view>
      </view>
    </view>
  </block>
</view>
