.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  margin-bottom: var(--spacing-md);
}

.nickname {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text);
}

.menu-card {
  padding: 0;
  overflow: hidden;
}

.version {
  text-align: center;
  margin-top: var(--spacing-xl);
}

.version text {
  font-size: 24rpx;
  color: var(--color-text-placeholder);
}
