.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.privacy-dialog {
  width: 600rpx;
  background: var(--color-bg-white);
  border-radius: var(--radius-lg);
  padding: var(--spacing-xl) var(--spacing-lg);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
}

.privacy-title {
  display: block;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: var(--spacing-lg);
}

.privacy-body {
  margin-bottom: var(--spacing-md);
}

.privacy-text {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
  margin-bottom: var(--spacing-sm);
}

.privacy-link {
  text-align: center;
  margin-bottom: var(--spacing-lg);
}

.privacy-link text {
  color: var(--color-primary);
  font-size: 26rpx;
  text-decoration: underline;
}

.privacy-actions {
  display: flex;
  justify-content: center;
}

.privacy-btn {
  width: 100%;
}
