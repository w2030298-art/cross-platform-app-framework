.nav-bar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 var(--spacing-md);
  position: relative;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-arrow {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid var(--color-text);
  border-bottom: 4rpx solid var(--color-text);
  transform: rotate(45deg);
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text);
}
