.content-card {
  margin-bottom: var(--spacing-md);
}

.card-body {
  display: flex;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.4;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-summary {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-meta {
  display: flex;
  align-items: center;
}

.card-date {
  font-size: 22rpx;
  color: var(--color-text-placeholder);
  margin-left: var(--spacing-sm);
}

.card-cover {
  width: 180rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  margin-left: var(--spacing-md);
  flex-shrink: 0;
  background: var(--color-bg);
}
